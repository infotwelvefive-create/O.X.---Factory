  var allR=(s.records||[]).slice().sort(function(a,b){return new Date(b.date)-new Date(a.date);});
  var w1r=allR.filter(function(r){return r.week==='Week 1';});
  var w2r=allR.filter(function(r){return r.week==='Week 2';});
  var wer=allR.filter(function(r){return r.week==='Week End';});
  return '<div class="tc" data-tech="'+esc(s.techName)+'">'
    +'<div class="tc-head" onclick="toggleTc(this)">'
    +'<div class="tc-hl"><div class="tc-av">👷</div>'
    +'<div><div class="tc-name">'+esc(s.techName)+'</div><div class="tc-sub">'+(s.records||[]).length+' items</div></div></div>'
    +'<div style="display:flex;align-items:center;gap:6px">'
    +'<div class="tc-total">📦 '+(s.total||0)+' ตัว</div>'
    +'<span class="tc-chev">▼</span></div></div>'
    +'<div class="tc-stats">'
    +'<div class="tc-stat"><div class="tc-sv">'+(s.week1||0)+'</div><div class="tc-sl">Week 1</div></div>'
    +'<div class="tc-stat"><div class="tc-sv">'+(s.week2||0)+'</div><div class="tc-sl">Week 2</div></div>'
    +'<div class="tc-stat"><div class="tc-sv">'+(s.weekEnd||0)+'</div><div class="tc-sl">Week End</div></div>'
    +'<div class="tc-stat"><div class="tc-sv">'+(s.total||0)+'</div><div class="tc-sl">รวม</div></div>'
    +'</div>'
    +'<div class="tc-body">'
    +'<div class="tc-wtabs">'
    +'<button class="wt-btn active" data-wk="all">ทั้งหมด ('+(s.records||[]).length+')</button>'
    +'<button class="wt-btn" data-wk="Week 1">Week 1 ('+w1r.length+')</button>'
    +'<button class="wt-btn" data-wk="Week 2">Week 2 ('+w2r.length+')</button>'
    +'<button class="wt-btn" data-wk="Week End">Week End ('+wer.length+')</button>'
    +'</div>'
    +'<div class="tc-panel active" data-p="all">'+allR.map(function(r){return rriHtml(r);}).join('')+'</div>'
    +'<div class="tc-panel" data-p="Week 1">'+w1r.map(function(r){return rriHtml(r);}).join('')+'</div>'
    +'<div class="tc-panel" data-p="Week 2">'+w2r.map(function(r){return rriHtml(r);}).join('')+'</div>'
    +'<div class="tc-panel" data-p="Week End">'+wer.map(function(r){return rriHtml(r);}).join('')+'</div>'
    +'</div></div>';
}
function rriHtml(r) {
  var imgs=r.imageUrls||[], MAX=6;
  var gHtml='';
  if(imgs.length){
    gHtml='<div class="rri-gallery">'
      +imgs.slice(0,MAX).map(function(u,i){
        if(i===MAX-1&&imgs.length>MAX)
          return '<div class="rri-more" onclick="lbFromRec(\''+r.id+'\','+i+',event)">+'+(imgs.length-MAX+1)+'</div>';
        return '<img src="'+u+'" loading="lazy" onclick="lbFromRec(\''+r.id+'\','+i+',event)" onerror="imgFallback(this)">';
      }).join('')+'</div>';
  }
  return '<div class="rri">'
    +'<div class="rri-top"><div>'
    +'<div class="rri-date">'+thDate(r.date)+'</div>'
    +'<div class="rri-meta">'+(r.modelName?esc(r.modelName)+' · ':'')+r.quantity+' ตัว · '+r.week+(imgs.length?' · '+imgs.length+' รูป':'')+'</div>'
    +'</div><button class="btn-del-r" onclick="doDelete(\''+r.id+'\',true)">🗑 ลบ</button></div>'
    +(r.note?'<div class="rri-note">'+esc(r.note)+'</div>':'')
    +gHtml+'</div>';
}
function toggleTc(hd) {
  var body=hd.parentElement.querySelector('.tc-body');
  var chev=hd.querySelector('.tc-chev');
  var open=body.classList.toggle('open');
  if(chev) chev.classList.toggle('open',open);
}
function switchTcPanel(card,wk) {
  card.querySelectorAll('.tc-panel').forEach(function(p){p.classList.remove('active');});
  var t=card.querySelector('.tc-panel[data-p="'+wk+'"]');
  if(t) t.classList.add('active');
}
function setupSearch() {
  var inp=q('#mgrSearch'); if(!inp) return;
  inp.oninput=function(){
    var v=inp.value.toLowerCase();
    qa('.tc').forEach(function(c){
      c.style.display=c.getAttribute('data-tech').toLowerCase().indexOf(v)>-1?'':'none';
    });
  };
}

// ── SHEET ──
async function openSheet() {
  var r=await apiCall('getSpreadsheetUrl');
  if(r&&r.success) window.open(r.url,'_blank');
  else { var url=getScriptUrl(); if(url) window.open(url,'_blank'); }
}

// ── MODAL / LIGHTBOX ──
function openModal()  { var m=q('#modal'); if(m) m.classList.add('open'); }
function closeModal() { var m=q('#modal'); if(m) m.classList.remove('open'); }
function onMBg(e)     { if(e.target===q('#modal')) closeModal(); }
function lbOpen(urls,idx) {
  if(!urls||!urls.length) return;
  S.lbUrls=urls; S.lbIdx=idx||0; lbShow();
  var lb=q('#lb'); if(lb) lb.classList.add('open');
}
function lbShow() {
  var img=q('#lbImg'), ctr=q('#lbCtr');
  if(img) img.src=S.lbUrls[S.lbIdx];
  if(ctr) ctr.textContent=(S.lbIdx+1)+' / '+S.lbUrls.length;
}
function lbNav(d,e) {
  if(e) e.stopPropagation();
  S.lbIdx=(S.lbIdx+d+S.lbUrls.length)%S.lbUrls.length; lbShow();
}
function lbClose() { var lb=q('#lb'); if(lb) lb.classList.remove('open'); }

// ── LOADER / TOAST ──
function showLoader(t){ setLdrTxt(t||'Loading...'); var e=q('#loader'); if(e) e.classList.add('show'); }
function setLdrTxt(t){ var e=q('#loaderTxt'); if(e) e.textContent=t; }
function hideLoader(){ var e=q('#loader'); if(e) e.classList.remove('show'); }
var _tt;
function toast(msg,type){
  var el=q('#toast'); if(!el) return;
  el.textContent=msg; el.className='toast show'+(type?' '+type:'');
  clearTimeout(_tt); _tt=setTimeout(function(){ el.classList.remove('show'); },3200);
}
function imgFallback(img) {
  var src=img.src||'';
  var m=src.match(/[?&]id=([^&]+)/);
  if(!m) m=src.match(/\/d\/([A-Za-z0-9_-]+)/);
  if(m&&img.getAttribute('data-tried')!=='1'){
    img.setAttribute('data-tried','1');
    img.src='https://lh3.googleusercontent.com/d/'+m[1]+'=s800';
  } else {
    img.style.display='none';
  }
}
</script>

