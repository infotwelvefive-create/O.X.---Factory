// ── API CALL ──
// Google Apps Script ต้องใช้ JSONP สำหรับ GET และ no-cors POST
// เพื่อหลีกเลี่ยง CORS error จาก GitHub Pages
async function apiCall(action, data) {
  var url = getScriptUrl();
  if (!url || S.demoMode) {
    return demoHandler(action, data);
  }
  try {
    if (data) {
      // POST — ส่งเป็น application/x-www-form-urlencoded เพื่อหลีกเลี่ยง preflight CORS
      var body = 'payload=' + encodeURIComponent(JSON.stringify({ action: action, ...data }));
      var res = await fetch(url, {
        method: 'POST',
        mode: 'cors',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: body
      });
      var json = await res.json();
      return json;
    } else {
      // GET — ใช้ JSONP เพื่อหลีกเลี่ยง CORS
      return await jsonpCall(url + '?action=' + action);
    }
  } catch(e) {
    console.error('API Error:', e);
    return { success: false, error: e.message };
  }
}

function jsonpCall(url) {
  return new Promise(function(resolve) {
    var cb = 'cb_' + Date.now() + '_' + Math.random().toString(36).slice(2);
    var script = document.createElement('script');
    var timer = setTimeout(function(){
      cleanup();
      resolve({ success:false, error:'Timeout' });
    }, 15000);
    function cleanup(){ delete window[cb]; script.remove(); clearTimeout(timer); }
    window[cb] = function(data){ cleanup(); resolve(data); };
    script.src = url + '&callback=' + cb;
    script.onerror = function(){ cleanup(); resolve({ success:false, error:'Script load error' }); };
    document.head.appendChild(script);
  });
}

