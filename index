    quantity:1, week:'Week 2', note:'', imageUrls:[]
  }
];
var _demoIdCounter = 100;

function demoHandler(action, data) {
  if (action === 'getTechnicians') {
    return { success:true, data: _demoTechs.slice() };
  }
  if (action === 'getAllRecords') {
    return { success:true, data: _demoRecords.slice().reverse() };
  }
  if (action === 'getSummaryReport') {
    var grouped = {};
    _demoTechs.forEach(function(t){ grouped[t] = { techName:t, records:[], week1:0, week2:0, weekEnd:0, total:0 }; });
    _demoRecords.forEach(function(r){
      if (!grouped[r.techName]) grouped[r.techName] = { techName:r.techName, records:[], week1:0, week2:0, weekEnd:0, total:0 };
      grouped[r.techName].records.push(r);
      grouped[r.techName].total += r.quantity;
      if (r.week==='Week 1') grouped[r.techName].week1 += r.quantity;
      if (r.week==='Week 2') grouped[r.techName].week2 += r.quantity;
      if (r.week==='Week End') grouped[r.techName].weekEnd += r.quantity;
    });
    var arr = Object.values(grouped).filter(function(g){ return g.records.length > 0; });
    return { success:true, data: arr };
  }
  if (action === 'saveWorkRecord') {
    var rec = {
      id: 'demo' + (++_demoIdCounter),
      techName: data.techName,
      modelName: data.modelName || '',
      date: data.date,
      quantity: data.quantity,
      week: data.week || weekOf(data.date),
      note: data.note || '',
      imageUrls: data.imageUrls || []
    };
    _demoRecords.push(rec);
    return { success:true, week: rec.week };
  }
  if (action === 'deleteRecord') {
    var idx = _demoRecords.findIndex(function(r){ return r.id === data.id; });
    if (idx > -1) _demoRecords.splice(idx, 1);
    return { success:true };
  }
  if (action === 'addTechnician') {
    if (!_demoTechs.includes(data.name)) _demoTechs.push(data.name);
    return { success:true };
  }
  if (action === 'deleteTechnician') {
    var idx = _demoTechs.indexOf(data.name);
    if (idx > -1) _demoTechs.splice(idx, 1);
    return { success:true };
  }
  if (action === 'uploadImage') {
    // In demo mode, return a placeholder
    return { success:true, url: 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100"><rect width="100" height="100" fill="%23f0f0f0"/><text x="50" y="55" text-anchor="middle" font-size="12" fill="%23999">IMG</text></svg>' };
  }
  if (action === 'getSpreadsheetUrl') {
    return { success:true, url: 'https://docs.google.com' };
  }
  return { success:false, error:'Unknown action' };
}

