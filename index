// ═══ Code.gs ═══
var SHEET_ID = 'YOUR_SPREADSHEET_ID'; // แทนที่ด้วย ID ของ Google Sheets ของคุณ
var FOLDER_ID = 'YOUR_DRIVE_FOLDER_ID'; // แทนที่ด้วย ID ของ Google Drive Folder สำหรับรูป

function doGet(e) {
  var action = e.parameter.action;
  try {
    if (action === 'getTechnicians') return jsonOut(getTechnicians());
    if (action === 'getAllRecords')   return jsonOut(getAllRecords());
    if (action === 'getSummaryReport') return jsonOut(getSummaryReport());
    if (action === 'getSpreadsheetUrl') return jsonOut(getSpreadsheetUrl());
    return jsonOut({ success: false, error: 'Unknown action: ' + action });
  } catch(e) {
    return jsonOut({ success: false, error: e.toString() });
  }
}

function doPost(e) {
  try {
    var data = JSON.parse(e.postData.contents);
    var action = data.action;
    if (action === 'saveWorkRecord')   return jsonOut(saveWorkRecord(data));
    if (action === 'deleteRecord')     return jsonOut(deleteRecord(data.id));
    if (action === 'addTechnician')    return jsonOut(addTechnician(data.name));
    if (action === 'deleteTechnician') return jsonOut(deleteTechnician(data.name));
    if (action === 'uploadImage')      return jsonOut(uploadImage(data.base64, data.filename, data.mimeType));
    return jsonOut({ success: false, error: 'Unknown action: ' + action });
  } catch(e) {
    return jsonOut({ success: false, error: e.toString() });
  }
}

function jsonOut(obj) {
  return ContentService.createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

function getSheet(name) {
  var ss = SpreadsheetApp.openById(SHEET_ID);
  var sh = ss.getSheetByName(name);
  if (!sh) {
    sh = ss.insertSheet(name);
    if (name === 'Records') {
      sh.appendRow(['ID','ชื่อช่าง','ชื่อรูป/รุ่น','วันที่','จำนวน','รอบ','หมายเหตุ','รูปภาพ (URLs)','Timestamp']);
      sh.getRange(1,1,1,9).setFontWeight('bold').setBackground('#f472b6').setFontColor('#ffffff');
    }
    if (name === 'Technicians') {
      sh.appendRow(['ชื่อช่าง','วันที่เพิ่ม']);
      sh.getRange(1,1,1,2).setFontWeight('bold').setBackground('#2563eb').setFontColor('#ffffff');
    }
  }
  return sh;
}

function getTechnicians() {
  var sh = getSheet('Technicians');
  var data = sh.getDataRange().getValues();
  var techs = [];
  for (var i = 1; i < data.length; i++) {
    if (data[i][0]) techs.push(String(data[i][0]));
  }
  return { success: true, data: techs };
}

function addTechnician(name) {
  var sh = getSheet('Technicians');
  var data = sh.getDataRange().getValues();
  for (var i = 1; i < data.length; i++) {
    if (String(data[i][0]).toLowerCase() === name.toLowerCase())
      return { success: false, error: 'ชื่อนี้มีอยู่แล้ว' };
  }
  sh.appendRow([name, new Date().toISOString()]);
  return { success: true };
}

function deleteTechnician(name) {
  var sh = getSheet('Technicians');
  var data = sh.getDataRange().getValues();
  for (var i = data.length - 1; i >= 1; i--) {
    if (String(data[i][0]) === name) { sh.deleteRow(i + 1); break; }
  }
  return { success: true };
}

function getAllRecords() {
  var sh = getSheet('Records');
  var data = sh.getDataRange().getValues();
  var records = [];
  for (var i = 1; i < data.length; i++) {
    if (!data[i][0]) continue;
    var urls = data[i][7] ? String(data[i][7]).split(',').map(function(u){ return u.trim(); }).filter(Boolean) : [];
    records.push({
      id: String(data[i][0]),
      techName: String(data[i][1]),
      modelName: String(data[i][2]||''),
      date: String(data[i][3]),
      quantity: Number(data[i][4])||0,
      week: String(data[i][5]),
      note: String(data[i][6]||''),
      imageUrls: urls
    });
  }
  records.reverse();
  return { success: true, data: records };
}

function saveWorkRecord(data) {
  var sh = getSheet('Records');
  var id = 'REC' + new Date().getTime();
  var week = weekOf(data.date);
  var urlStr = (data.imageUrls||[]).join(', ');
  sh.appendRow([id, data.techName, data.modelName||'', data.date, data.quantity, week, data.note||'', urlStr, new Date().toISOString()]);
  // Insert clickable image formulas in a new column if desired
  if (data.imageUrls && data.imageUrls.length > 0) {
    var row = sh.getLastRow();
    var imgFormulas = data.imageUrls.map(function(u){
      return '=IMAGE("'+u+'",4,60,60)';
    });
    // Add images to columns 9+ (column I onwards)
    for (var i = 0; i < imgFormulas.length && i < 5; i++) {
      sh.getRange(row, 9+i).setFormula(imgFormulas[i]);
    }
  }
  return { success: true, week: week };
}

function deleteRecord(id) {
  var sh = getSheet('Records');
  var data = sh.getDataRange().getValues();
  for (var i = data.length - 1; i >= 1; i--) {
    if (String(data[i][0]) === id) { sh.deleteRow(i + 1); break; }
  }
  return { success: true };
}

function uploadImage(base64, filename, mimeType) {
  try {
    var folder = DriveApp.getFolderById(FOLDER_ID);
    var blob = Utilities.newBlob(Utilities.base64Decode(base64), mimeType, filename);
    var file = folder.createFile(blob);
    file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
    var fileId = file.getId();
    var url = 'https://drive.google.com/thumbnail?id=' + fileId + '&sz=w800';
    return { success: true, url: url, fileId: fileId };
  } catch(e) {
    return { success: false, error: e.toString() };
  }
}

function getSummaryReport() {
  var recs = getAllRecords();
  if (!recs.success) return recs;
  var grouped = {};
  recs.data.forEach(function(r) {
    if (!grouped[r.techName]) {
      grouped[r.techName] = { techName: r.techName, records: [], week1: 0, week2: 0, weekEnd: 0, total: 0 };
    }
    grouped[r.techName].records.push(r);
    grouped[r.techName].total += r.quantity;
    if (r.week === 'Week 1') grouped[r.techName].week1 += r.quantity;
    if (r.week === 'Week 2') grouped[r.techName].week2 += r.quantity;
    if (r.week === 'Week End') grouped[r.techName].weekEnd += r.quantity;
  });
  return { success: true, data: Object.values(grouped) };
}

function getSpreadsheetUrl() {
  var ss = SpreadsheetApp.openById(SHEET_ID);
  return { success: true, url: ss.getUrl() };
}

function weekOf(ds) {
  if (!ds) return '';
  var d = new Date(ds + 'T00:00:00');
  if (isNaN(d.getTime())) return '';
  var day = d.getDate();
  var last = new Date(d.getFullYear(), d.getMonth() + 1, 0).getDate();
  if (day === last) return 'Week End';
  return day <= 14 ? 'Week 1' : 'Week 2';
}

