function onImgSel(evt) {
  Array.from(evt.target.files).forEach(function(file){
    if(!file.type.startsWith('image/')) return;
    // Compress image before storing
    var reader=new FileReader();
    reader.onload=function(e){
      compressImage(e.target.result, file.type, function(compressed, preview){
        S.pendingImgs.push({
          base64: compressed.split(',')[1],
          mimeType: file.type,
          filename: file.name,
          preview: preview
        });
        renderPrev();
      });
    };
    reader.readAsDataURL(file);
  });
  evt.target.value='';
}

function compressImage(dataUrl, mimeType, cb) {
  var img = new Image();
  img.onload = function(){
    var MAX = 1200;
    var w = img.width, h = img.height;
    if(w > MAX || h > MAX){
      if(w > h){ h = Math.round(h * MAX / w); w = MAX; }
      else { w = Math.round(w * MAX / h); h = MAX; }
    }
    var canvas = document.createElement('canvas');
    canvas.width = w; canvas.height = h;
    canvas.getContext('2d').drawImage(img, 0, 0, w, h);
    var compressed = canvas.toDataURL('image/jpeg', 0.75);
    cb(compressed, compressed);
  };
  img.src = dataUrl;
}

