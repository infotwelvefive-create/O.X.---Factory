function weekOf(ds) {
  if(!ds) return '';
  var d=new Date(ds+'T00:00:00'); if(isNaN(d)) return '';
  var day=d.getDate();
  var last=new Date(d.getFullYear(),d.getMonth()+1,0).getDate();
  if(day===last) return 'Week End';
  return day<=14?'Week 1':'Week 2';
}
function thDate(ds) {
  if(!ds) return '';
  var d=new Date((typeof ds==='string'&&ds.indexOf('-')>-1)?ds+'T00:00:00':ds);
  if(isNaN(d)) return String(ds);
  var mo=['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
  return d.getDate()+' '+mo[d.getMonth()]+' '+(d.getFullYear()+543);
}

