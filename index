var _demoTechs = ['วิกี้','รส','ริน','แอน','พลอย','วรรณ'];
var _demoRecords = [
  {
    id:'demo1', techName:'วิกี้', modelName:'เทส', date:'2026-03-20',
    quantity:5, week:'Week 2', note:'', imageUrls:[]
  },
